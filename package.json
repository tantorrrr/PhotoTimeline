{
  "name": "photo-timeline",
  "version": "0.1.0",
  "description": "Lightweight Windows photo viewer - timeline view of folders",
  "main": "out/main/index.js",
  "author": "lampd",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10.8",
    "better-sqlite3": "^11.5.0",
    "exifr": "^7.1.3",
    "p-limit": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  },
  "build": {
    "appId": "com.lampd.phototimeline",
    "productName": "PhotoTimeline",
    "win": {
      "target": "nsis"
    },
    "files": [
      "out/**/*",
      "package.json"
    ]
  }
}
